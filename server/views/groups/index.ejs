<%- include('_head') %>

<style>
  .page {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center;
    padding: 60px 20px;
    background: var(--bg-deep);
  }

  .page-header {
    width: 100%; max-width: 760px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 36px;
  }

  .logo-row {
    display: flex; align-items: center; gap: 12px;
  }
  .logo-mark {
    width: 38px; height: 38px;
    border-radius: 11px;
    background: linear-gradient(135deg, var(--indigo), var(--violet));
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }
  .page-title { font-size: 22px; font-weight: 700; color: var(--text-1); letter-spacing: -0.03em; }
  .page-sub   { font-size: 13px; color: var(--text-3); margin-top: 2px; }

  /* ── Group Grid ── */
  .groups-grid {
    width: 100%; max-width: 760px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }

  .group-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 22px 20px;
    display: flex; flex-direction: column; gap: 14px;
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
    cursor: pointer;
    text-decoration: none;
  }
  .group-card:hover {
    border-color: rgba(99,102,241,0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }

  .group-card-top { display: flex; align-items: center; gap: 12px; }
  .group-card-name { font-size: 15px; font-weight: 700; color: var(--text-1); }
  .group-card-desc { font-size: 12px; color: var(--text-3); line-height: 1.5; }
  .group-card-meta { font-size: 11px; color: var(--text-4); display: flex; align-items: center; gap: 5px; }
  .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-4); }

  /* ── Empty ── */
  .empty-state {
    width: 100%; max-width: 760px;
    text-align: center;
    padding: 80px 20px;
    color: var(--text-4);
  }
  .empty-state .icon { font-size: 48px; margin-bottom: 16px; }
  .empty-state h3 { font-size: 18px; font-weight: 700; color: var(--text-2); margin-bottom: 8px; }
  .empty-state p  { font-size: 14px; line-height: 1.6; }

  /* ── Create modal form ── */
  .field-row { margin-bottom: 18px; }
  .modal-actions { display: flex; gap: 10px; margin-top: 24px; }
  .modal-actions .btn { flex: 1; padding: 11px; }
</style>

<div class="page">
  <!-- Header -->
  <div class="page-header">
    <div class="logo-row">
      <div class="logo-mark">💬</div>
      <div>
        <div class="page-title">Spaces</div>
        <div class="page-sub">Your group conversations</div>
      </div>
    </div>
    <button class="btn btn-primary" onclick="openModal('createModal')">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Group
    </button>
  </div>

  <!-- Toast -->
  <% if (error) { %>
    <div class="toast error">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <%= error %>
    </div>
  <% } %>
  <% if (success) { %>
    <div class="toast success">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
      <%= success %>
    </div>
  <% } %>

  <!-- Group list -->
  <% if (groups.length === 0) { %>
    <div class="empty-state">
      <div class="icon">🌌</div>
      <h3>No groups yet</h3>
      <p>Create your first group and invite your teammates.</p>
    </div>
  <% } else { %>
    <div class="groups-grid">
      <% groups.forEach(function(g) {
        const initials = g.name.slice(0, 2).toUpperCase();
        const colors = ['#6366f1','#8b5cf6','#ec4899','#f97316','#14b8a6','#06b6d4','#f59e0b'];
        const color  = colors[g.name.charCodeAt(0) % colors.length];
      %>
        <a class="group-card" href="/groups/<%= g._id %>">
          <div class="group-card-top">
            <div class="avatar" style="width:44px;height:44px;background:<%= color %>;font-size:16px;">
              <%= initials %>
            </div>
            <div>
              <div class="group-card-name"><%= g.name %></div>
              <div class="group-card-meta">
                <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                <%= g.members.length %> member<%= g.members.length !== 1 ? 's' : '' %>
              </div>
            </div>
          </div>
          <% if (g.description) { %>
            <div class="group-card-desc"><%= g.description %></div>
          <% } %>
          <div class="group-card-meta">
            by <%= g.creator?.username || 'unknown' %>
            <span class="meta-dot"></span>
            <%= new Date(g.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>

<!-- Create Group Modal -->
<div class="modal-overlay" id="createModal">
  <div class="modal" onclick="event.stopPropagation()">
    <h3>
      <svg width="18" height="18" fill="none" stroke="var(--indigo)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="vertical-align:middle;margin-right:8px"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Group
    </h3>

    <form method="POST" action="/groups">
      <div class="field-row">
        <label class="field-label">Group Name</label>
        <input class="field-input" type="text" name="name" placeholder="e.g. Design Team" required autofocus />
      </div>
      <div class="field-row">
        <label class="field-label">Description <span style="font-weight:400;opacity:.5">(optional)</span></label>
        <input class="field-input" type="text" name="description" placeholder="What's this group about?" />
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-secondary" onclick="closeModal('createModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Group</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openModal(id)  { document.getElementById(id).classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  document.querySelectorAll('.modal-overlay').forEach(el => {
    el.addEventListener('click', () => el.classList.remove('open'));
  });
</script>

</body>
</html>
