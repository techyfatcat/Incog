<%- include('_head') %>

<style>
  /* ── Layout ─────────────────────────────────────────────────────────── */
  .chat-layout {
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────── */
  .sidebar {
    width: 256px;
    flex-shrink: 0;
    background: var(--bg-panel);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .sidebar-header {
    padding: 18px 16px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }

  .sidebar-logo {
    display: flex; align-items: center; gap: 10px;
  }
  .sidebar-logo-mark {
    width: 32px; height: 32px;
    border-radius: 9px;
    background: linear-gradient(135deg, var(--indigo), var(--violet));
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }
  .sidebar-title {
    font-size: 16px; font-weight: 700; color: var(--text-1);
    letter-spacing: -0.02em;
  }

  .sidebar-new-btn {
    width: 30px; height: 30px;
    border-radius: 8px;
    background: var(--indigo-dim);
    border: 1px solid rgba(99,102,241,0.3);
    color: #818cf8;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
    text-decoration: none;
  }
  .sidebar-new-btn:hover { background: rgba(99,102,241,0.25); }

  .sidebar-section-label {
    padding: 14px 16px 6px;
    font-size: 10px; font-weight: 700;
    color: var(--text-4);
    letter-spacing: 0.12em; text-transform: uppercase;
  }

  .sidebar-groups { flex: 1; overflow-y: auto; padding: 4px 8px; }

  .group-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 10px;
    border-radius: 10px;
    border: none;
    width: 100%; text-align: left;
    cursor: pointer;
    transition: all 0.12s;
    text-decoration: none;
    color: var(--text-2);
    border-left: 3px solid transparent;
    margin-bottom: 2px;
  }
  .group-item:hover  { background: var(--bg-ele); color: var(--text-1); }
  .group-item.active {
    background: var(--indigo-dim);
    border-left-color: var(--indigo);
    color: var(--text-1);
  }

  .group-item-name {
    font-size: 13px; font-weight: 600;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    flex: 1;
  }

  .sidebar-back {
    padding: 14px 16px;
    border-top: 1px solid var(--border);
  }
  .sidebar-back a {
    display: flex; align-items: center; gap: 7px;
    font-size: 13px; color: var(--text-3);
    text-decoration: none;
    transition: color 0.15s;
  }
  .sidebar-back a:hover { color: var(--text-1); }

  /* ── Chat Area ───────────────────────────────────────────────────────── */
  .chat-area {
    flex: 1;
    display: flex; flex-direction: column;
    height: 100%;
    overflow: hidden;
    background: var(--bg-deep);
  }

  /* Header */
  .chat-header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-panel);
    display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0;
    gap: 12px;
  }

  .chat-header-left { display: flex; align-items: center; gap: 12px; }

  .chat-header-info .name {
    font-size: 15px; font-weight: 700; color: var(--text-1);
    letter-spacing: -0.02em;
  }
  .chat-header-info .meta {
    font-size: 12px; color: var(--text-4);
    margin-top: 2px;
  }

  .chat-header-actions { display: flex; align-items: center; gap: 8px; }

  /* Messages */
  .messages-wrap {
    flex: 1; overflow-y: auto;
    padding: 20px 0 12px;
    display: flex; flex-direction: column;
  }

  /* Date divider */
  .date-divider {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 24px 8px;
  }
  .date-divider-line { flex: 1; height: 1px; background: var(--border); }
  .date-divider-label {
    font-size: 10px; font-weight: 700;
    color: var(--text-4);
    text-transform: uppercase; letter-spacing: 0.1em;
    white-space: nowrap;
  }

  /* Message row */
  .msg-row {
    display: flex;
    padding: 2px 20px;
    gap: 10px;
    align-items: flex-end;
    position: relative;
  }
  .msg-row.own { flex-direction: row-reverse; }

  .msg-avatar-slot { width: 30px; flex-shrink: 0; }

  .msg-body { max-width: 65%; display: flex; flex-direction: column; }
  .own .msg-body { align-items: flex-end; }

  .msg-meta {
    display: flex; align-items: center; gap: 7px;
    margin-bottom: 4px;
  }
  .msg-username {
    font-size: 12px; font-weight: 600; color: #818cf8;
  }
  .msg-time {
    font-size: 10px; color: var(--text-4);
    font-family: var(--mono);
  }

  .msg-bubble {
    padding: 10px 15px;
    border-radius: 18px;
    font-size: 14px; line-height: 1.55;
    word-break: break-word;
    position: relative;
  }
  .msg-bubble.theirs {
    background: var(--bg-ele);
    color: var(--text-1);
    border-bottom-left-radius: 4px;
  }
  .msg-bubble.mine {
    background: linear-gradient(135deg, var(--indigo), var(--violet));
    color: #fff;
    border-bottom-right-radius: 4px;
    box-shadow: 0 2px 16px var(--indigo-glow);
  }

  /* Delete button */
  .msg-delete-form { display: none; }
  .msg-row:hover .msg-delete-form { display: inline; }

  .msg-delete-btn {
    background: rgba(239,68,68,0.12);
    border: 1px solid rgba(239,68,68,0.2);
    color: #f87171;
    border-radius: 7px;
    padding: 5px 6px;
    cursor: pointer;
    display: flex; align-items: center;
    align-self: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .msg-delete-btn:hover { background: rgba(239,68,68,0.25); }

  .no-time .msg-meta { display: none; }
  .no-time .msg-avatar-slot { opacity: 0; pointer-events: none; }

  /* ── Input Bar ───────────────────────────────────────────────────────── */
  .chat-input-bar {
    padding: 14px 18px;
    border-top: 1px solid var(--border);
    background: var(--bg-panel);
    flex-shrink: 0;
  }

  .chat-form {
    display: flex; align-items: center; gap: 10px;
  }

  .chat-input {
    flex: 1;
    background: var(--bg-ele);
    border: 1px solid var(--border-2);
    border-radius: 14px;
    padding: 11px 18px;
    color: var(--text-1);
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .chat-input:focus {
    border-color: var(--indigo);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
  }
  .chat-input::placeholder { color: var(--text-4); }

  .send-btn {
    width: 44px; height: 44px;
    border-radius: 13px;
    background: linear-gradient(135deg, var(--indigo), var(--violet));
    border: none;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    box-shadow: 0 2px 16px var(--indigo-glow);
    transition: opacity 0.15s, transform 0.1s;
  }
  .send-btn:hover   { opacity: 0.9; }
  .send-btn:active  { transform: scale(0.94); }

  /* ── Invite Panel ────────────────────────────────────────────────────── */
  .invite-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px;
    margin-top: 6px;
  }
  .invite-box-label {
    font-size: 11px; font-weight: 700;
    color: var(--text-4);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 10px;
  }
  .invite-url-row { display: flex; gap: 8px; }
  .invite-url-field {
    flex: 1;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 9px 13px;
    font-size: 12px;
    font-family: var(--mono);
    color: var(--text-3);
    word-break: break-all;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .invite-actions { display: flex; gap: 6px; }

  /* ── Members panel ─────────────────────────────────────────────────── */
  .members-panel {
    padding: 10px 16px 14px;
    border-top: 1px solid var(--border);
  }
  .members-label {
    font-size: 10px; font-weight: 700;
    color: var(--text-4);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .members-list { display: flex; flex-direction: column; gap: 6px; }
  .member-row {
    display: flex; align-items: center; gap: 8px;
  }
  .member-name { font-size: 12px; color: var(--text-2); }
  .member-badge {
    font-size: 9px; font-weight: 700;
    padding: 2px 6px; border-radius: 4px;
    background: var(--indigo-dim);
    color: #818cf8;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
</style>

<div class="chat-layout">

  <!-- ── Sidebar ── -->
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">
        <div class="sidebar-logo-mark">💬</div>
        <span class="sidebar-title">Spaces</span>
      </div>
      <a href="/groups" class="sidebar-new-btn" title="All groups">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      </a>
    </div>

    <div class="sidebar-section-label">Your Groups</div>

    <div class="sidebar-groups">
      <% allGroups.forEach(function(g) {
        const isActive = g._id.toString() === group._id.toString();
        const initials = g.name.slice(0, 2).toUpperCase();
        const colors = ['#6366f1','#8b5cf6','#ec4899','#f97316','#14b8a6','#06b6d4','#f59e0b'];
        const color  = colors[g.name.charCodeAt(0) % colors.length];
      %>
        <a href="/groups/<%= g._id %>" class="group-item <%= isActive ? 'active' : '' %>">
          <div class="avatar" style="width:30px;height:30px;background:<%= color %>;font-size:11px;flex-shrink:0;">
            <%= initials %>
          </div>
          <span class="group-item-name"><%= g.name %></span>
        </a>
      <% }); %>

      <a href="/groups" class="group-item" style="margin-top:8px;color:var(--text-4);">
        <div style="width:30px;height:30px;border-radius:50%;background:var(--bg-ele);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </div>
        <span class="group-item-name">New Group</span>
      </a>
    </div>

    <!-- Members list -->
    <div class="members-panel">
      <div class="members-label">Members</div>
      <div class="members-list">
        <% group.members.slice(0, 6).forEach(function(m) { %>
          <div class="member-row">
            <% const mc = ['#6366f1','#8b5cf6','#ec4899','#f97316','#14b8a6'][m.username.charCodeAt(0) % 5]; %>
            <div class="avatar" style="width:22px;height:22px;background:<%= mc %>;font-size:9px;">
              <%= m.username.slice(0,2).toUpperCase() %>
            </div>
            <span class="member-name"><%= m.username %></span>
            <% if (group.creator && m._id.toString() === group.creator._id.toString()) { %>
              <span class="member-badge">owner</span>
            <% } %>
          </div>
        <% }); %>
        <% if (group.members.length > 6) { %>
          <div class="member-row">
            <span style="font-size:12px;color:var(--text-4);">+<%= group.members.length - 6 %> more</span>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ── Chat Area ── -->
  <div class="chat-area">

    <!-- Header -->
    <div class="chat-header">
      <div class="chat-header-left">
        <% const hc = ['#6366f1','#8b5cf6','#ec4899','#f97316','#14b8a6','#06b6d4','#f59e0b'][group.name.charCodeAt(0) % 7]; %>
        <div class="avatar" style="width:40px;height:40px;background:<%= hc %>;font-size:15px;">
          <%= group.name.slice(0,2).toUpperCase() %>
        </div>
        <div class="chat-header-info">
          <div class="name"># <%= group.name %></div>
          <div class="meta">
            <%= group.members.length %> member<%= group.members.length !== 1 ? 's' : '' %>
            <% if (group.description) { %> · <%= group.description %><% } %>
          </div>
        </div>
      </div>

      <div class="chat-header-actions">
        <button class="btn btn-secondary" onclick="openModal('inviteModal')" style="font-size:13px;padding:8px 14px;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
          Invite
        </button>
      </div>
    </div>

    <!-- Toast -->
    <% if (error) { %>
      <div class="toast error" style="position:fixed;top:20px;right:20px;z-index:9999;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
    <% } %>
    <% if (success) { %>
      <div class="toast success" style="position:fixed;top:20px;right:20px;z-index:9999;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        <%= success %>
      </div>
    <% } %>

    <!-- Messages -->
    <div class="messages-wrap" id="messagesWrap">

      <% if (messageItems.length === 0) { %>
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 24px;color:var(--text-4);">
          <div style="font-size:48px;margin-bottom:14px;">🚀</div>
          <div style="font-size:15px;font-weight:600;color:var(--text-2);margin-bottom:6px;">No messages yet</div>
          <div style="font-size:13px;">Be the first to say something in <strong style="color:var(--text-1)">#<%= group.name %></strong>!</div>
        </div>
      <% } %>

      <%
        let prevSenderId = null;
        let prevType = null;
      %>

      <% messageItems.forEach(function(item, idx) { %>

        <% if (item.type === 'date') { %>
          <%  prevSenderId = null; %>
          <div class="date-divider">
            <div class="date-divider-line"></div>
            <span class="date-divider-label"><%= item.label %></span>
            <div class="date-divider-line"></div>
          </div>

        <% } else { %>
          <%
            const isOwn = item.isOwn;
            const senderId = item.sender._id.toString();
            const showMeta = (prevType === 'date') || (prevSenderId !== senderId);
            prevSenderId = senderId;
            prevType = 'msg';
            const mc2 = ['#6366f1','#8b5cf6','#ec4899','#f97316','#14b8a6'][item.sender.username.charCodeAt(0) % 5];
          %>

          <div class="msg-row <%= isOwn ? 'own' : '' %> <%= !showMeta ? 'no-time' : '' %>">

            <!-- Avatar slot (others only) -->
            <% if (!isOwn) { %>
              <div class="msg-avatar-slot">
                <% if (showMeta) { %>
                  <div class="avatar" style="width:30px;height:30px;background:<%= mc2 %>;font-size:11px;">
                    <%= item.sender.username.slice(0,2).toUpperCase() %>
                  </div>
                <% } %>
              </div>
            <% } %>

            <!-- Body -->
            <div class="msg-body">
              <% if (showMeta) { %>
                <div class="msg-meta">
                  <% if (!isOwn) { %>
                    <span class="msg-username"><%= item.sender.username %></span>
                  <% } %>
                  <span class="msg-time"><%= item.formattedTime %></span>
                </div>
              <% } %>
              <div style="display:flex;align-items:center;gap:7px;flex-direction:<%= isOwn ? 'row-reverse' : 'row' %>;">
                <div class="msg-bubble <%= isOwn ? 'mine' : 'theirs' %>">
                  <%= item.content %>
                </div>
                <% if (isOwn) { %>
                  <form class="msg-delete-form" method="POST" action="/groups/<%= group._id %>/messages/<%= item._id %>/delete">
                    <button type="submit" class="msg-delete-btn" title="Delete message"
                      onclick="return confirm('Delete this message?')">
                      <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>

          </div>

        <% } %>
      <% }); %>

      <div id="bottom" style="height:8px;"></div>
    </div>

    <!-- Input bar -->
    <div class="chat-input-bar">
      <form class="chat-form" method="POST" action="/groups/<%= group._id %>/messages">
        <input
          class="chat-input"
          type="text"
          name="content"
          placeholder="Message #<%= group.name %>…"
          maxlength="2000"
          autocomplete="off"
          required
          autofocus
        />
        <button type="submit" class="send-btn" title="Send">
          <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </form>
    </div>
  </div>
</div>

<!-- ── Invite Modal ── -->
<div class="modal-overlay" id="inviteModal">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:480px;">
    <h3>
      <svg width="17" height="17" fill="none" stroke="var(--indigo)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="vertical-align:middle;margin-right:8px"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
      Invite to <span style="color:var(--indigo)"><%= group.name %></span>
    </h3>

    <p style="font-size:13px;color:var(--text-3);line-height:1.6;margin-bottom:18px;">
      Share this link with anyone. They'll join the group automatically when they open it.
    </p>

    <div class="invite-box">
      <div class="invite-box-label">Invite Link</div>
      <div class="invite-url-row">
        <div class="invite-url-field" id="inviteUrlText"><%= inviteUrl || 'No invite link generated.' %></div>
        <div class="invite-actions">
          <button class="btn-icon" onclick="copyInvite()" title="Copy link" id="copyBtn">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          </button>
          <form method="POST" action="/groups/<%= group._id %>/invite/regenerate" style="display:inline;">
            <button type="submit" class="btn-icon" title="Regenerate link">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:10px;margin-top:14px;padding:11px 14px;background:var(--bg-ele);border-radius:10px;">
      <svg width="15" height="15" fill="none" stroke="var(--text-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      <span style="font-size:13px;color:var(--text-3);">
        <%= group.members.length %> member<%= group.members.length !== 1 ? 's' : '' %> in this group
      </span>
    </div>

    <div style="margin-top:20px;text-align:right;">
      <button class="btn btn-secondary" onclick="closeModal('inviteModal')">Close</button>
    </div>
  </div>
</div>

<script>
  // Auto-scroll to bottom
  (function() {
    const wrap = document.getElementById('messagesWrap');
    if (wrap) wrap.scrollTop = wrap.scrollHeight;
  })();

  // Hash scroll
  if (window.location.hash === '#bottom') {
    const el = document.getElementById('bottom');
    if (el) el.scrollIntoView();
    history.replaceState(null, '', window.location.pathname + window.location.search);
  }

  // Modal helpers
  function openModal(id)  { document.getElementById(id).classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  document.querySelectorAll('.modal-overlay').forEach(el => {
    el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
  });

  // Copy invite
  function copyInvite() {
    const url = document.getElementById('inviteUrlText').textContent.trim();
    navigator.clipboard.writeText(url).then(() => {
      const btn = document.getElementById('copyBtn');
      btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>';
      btn.style.borderColor = 'rgba(74,222,128,0.4)';
      setTimeout(() => {
        btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
        btn.style.borderColor = '';
      }, 2000);
    });
  }

  // Auto-dismiss toasts
  setTimeout(() => {
    document.querySelectorAll('.toast').forEach(t => t.remove());
  }, 4000);

  // Auto-refresh messages every 5 seconds (SSR polling approach)
  setInterval(() => {
    // Preserve scroll position near bottom before reload
    const wrap = document.getElementById('messagesWrap');
    const nearBottom = wrap && (wrap.scrollHeight - wrap.scrollTop - wrap.clientHeight < 120);
    if (nearBottom) {
      // Soft reload: fetch and replace message area
      fetch(window.location.pathname, { credentials: 'same-origin' })
        .then(r => r.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newWrap = doc.getElementById('messagesWrap');
          if (newWrap) {
            wrap.innerHTML = newWrap.innerHTML;
            wrap.scrollTop = wrap.scrollHeight;
          }
        })
        .catch(() => {});
    }
  }, 5000);
</script>

</body>
</html>
